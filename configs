<group name="local,syslog,sshd,">

  <rule id="100001" level="8">
    <if_sid>5716</if_sid>
    <description>sshd: authentication failed - Possible brute force attempt</description>
    <group>authentication_failed,bruteforce,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<group name="ransomware_fim">

  <rule id="100002" level="10">
    <if_sid>550</if_sid>
    <match>.locked</match>
    <description>Suspicious File Extension (.locked) - Possible Ransomware</description>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

  <rule id="100003" level="12" frequency="10" timeframe="60">
    <if_matched_sid>550</if_matched_sid>
    <description>Mass File Changes Detected - Possible Ransomware</description>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

</group>

<group name="ransomware_shadowcopy">

  <rule id="100004" level="12">
    <field name="win.eventdata.Image">vssadmin.exe</field>
    <match>delete shadows</match>
    <description>Shadow Copy Deletion - Possible Ransomware</description>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

</group>
